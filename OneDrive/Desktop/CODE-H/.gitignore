# Dependencies
node_modules/
.pnp
.pnp.js

# Build output
dist/
build/
out/

# Environment variables  ← NEVER commit these
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS & editor
.DS_Store
Thumbs.db
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Vite cache
.vite/
vite.config.js.timestamp-*

# ESLint cache
.eslintcache

# TypeScript
*.tsbuildinfo

# Coverage / testing
coverage/
.nyc_output/
